# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/tt-office-solutions

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Auth ────────────────────────────────────────────────────────────────────
# Change to a long random string in production!
JWT_SECRET=your-super-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d

# Default admin credentials (used only on first boot if no user exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com

# ─── Upload ──────────────────────────────────────────────────────────────────
# Max upload size in bytes (default 5MB)
MAX_FILE_SIZE=5242880
